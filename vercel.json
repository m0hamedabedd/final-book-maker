{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/rewrite.ts": {
      "maxDuration": 60
    },
    "api/playlist.py": {
      "maxDuration": 30
    },
    "api/video.py": {
      "maxDuration": 15
    },
    "api/transcript.py": {
      "maxDuration": 30
    }
  }
}
